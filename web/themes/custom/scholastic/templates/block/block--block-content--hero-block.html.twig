{% set _ = attach_library('scholastic/block--hero') %}
{#
  block--block-content--hero-block.html.twig
#}

<div class="row g-5 align-items-center">

  {# ── Left: text content ── #}
  <div class="col-12 col-lg-6 d-flex flex-column gap-3 position-relative" style="z-index:1;">

    {% if content.field_eyebrow|render %}
      <div class="d-flex">
        <span class="py-1 px-3 bg-secondary-container text-on-secondary-container
                     small fw-bold text-uppercase rounded font-label"
              style="letter-spacing:.1em;">
          {{ content.field_eyebrow|render|striptags|trim }}
        </span>
      </div>
    {% endif %}

    <h1 class="display-4 fw-bolder font-headline lh-1 mb-0" style="color:#001f3c; letter-spacing:-.03em;">
      {{ content.field_heading }}
      {% if content.field_heading_accent|render %}
        <span class="d-block" style="color:#1460a4;">
          {{ content.field_heading_accent }}
        </span>
      {% endif %}
    </h1>

    {% if content.field_description|render %}
      <div class="fs-5 text-on-surface-variant lh-base font-body" style="max-width:32rem;">
        {{ content.field_description }}
      </div>
    {% endif %}

    <div class="d-flex flex-column flex-sm-row gap-3 pt-2">
      {% if content.field_cta_primary|render %}
        <div class="cta-primary-wrap">{{ content.field_cta_primary }}</div>
      {% endif %}
      {% if content.field_cta_secondary|render %}
        <div class="cta-secondary-wrap">{{ content.field_cta_secondary }}</div>
      {% endif %}
    </div>

  </div>

  {# ── Right: hero image (desktop only) ── #}
  <div class="col-lg-6 d-none d-lg-block position-relative">

    {# Decorative backing card — inset positive so it's smaller than the image #}
    <div class="position-absolute rounded-4 bg-secondary-container"
         style="inset:1.25rem 0 -1.25rem 1.25rem; opacity:.35; transform:rotate(1.5deg); transition:transform .5s; z-index:0;"></div>

    {# Image container #}
    <div class="position-relative overflow-hidden rounded-4 shadow"
         style="aspect-ratio:4/5; z-index:1;"
         data-hero-img-wrap>
      {{ content.field_hero_image }}
    </div>

  </div>

</div>
