{#
  block--block-content--section-header.html.twig
#}

<div class="d-flex justify-content-between align-items-end mb-5">

  <div>
    {% if content.field_section_eyebrow|render %}
      <span class="d-inline-block text-uppercase fw-bold small mb-2 text-surface-tint font-label"
            style="letter-spacing:.1em;">
        {{ content.field_section_eyebrow|render|striptags|trim }}
      </span>
    {% endif %}
    <h2 class="display-6 fw-bolder font-headline mb-0" style="color:#001f3c;">
      {{ content.field_section_header_heading }}
    </h2>
  </div>

  <div class="d-flex align-items-center gap-1 fw-bold text-decoration-none" style="color:#001f3c;">
    {{ content.field_link }}
    <span aria-hidden="true">&rarr;</span>
  </div>

</div>
