{% set _ = attach_library('scholastic/block--feature-grid') %}
{#
  block--block-content--feature-grid.html.twig

  Fields:
    field_section_heading
    field_section_description
    field_features
#}

<div class="row g-4 g-md-5 align-items-start">

  {# ── Left: section copy ── #}
  <div class="col-12 col-md-5">

    {% if content.field_section_heading|render %}
      <h2 class="display-6 fw-bolder font-headline lh-sm mb-4" style="color:#001f3c; letter-spacing:-.02em;">
        {{ content.field_section_heading }}
      </h2>
    {% endif %}

    {% if content.field_section_description|render %}
      <p class="text-on-surface-variant lh-base font-body">
        {{ content.field_section_description }}
      </p>
    {% endif %}

  </div>

  {# ── Right: feature items grid ── #}
  <div class="col-12 col-md-7">
    <div class="feature-items-grid" data-feature-grid>
      {{ content.field_features }}
    </div>
  </div>

</div>
