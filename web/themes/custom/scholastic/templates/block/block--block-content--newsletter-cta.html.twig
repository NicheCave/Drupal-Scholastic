{#
  block--block-content--newsletter-cta.html.twig

  Fields:
    field_newsletter_heading
    field_newsletter_description
#}

<div class="bg-surface-container-low rounded-4 p-5 p-lg-5 text-center position-relative overflow-hidden">

  {# Decorative circles #}
  <div class="position-absolute rounded-circle pe-none"
       style="width:16rem;height:16rem;background:rgba(0,52,95,.05);top:0;right:0;transform:translate(50%,-50%);"></div>
  <div class="position-absolute rounded-circle pe-none"
       style="width:8rem;height:8rem;background:rgba(213,228,247,.1);bottom:0;left:0;transform:translate(-50%,50%);"></div>

  <div class="position-relative mx-auto" style="max-width:38rem; z-index:1;">

    <h2 class="display-6 fw-bolder font-headline mb-4" style="color:#001f3c;">
      {{ content.field_newsletter_heading }}
    </h2>

    <p class="text-on-surface-variant mb-5 lh-base">
      {{ content.field_newsletter_description }}
    </p>

    {# Bootstrap input-group for the email + button #}
    <div class="input-group mx-auto" style="max-width:26rem;">
      <input type="email"
             class="form-control form-control-lg border-0 shadow-none"
             placeholder="email@example.com"
             style="background:#fff;">
      <button class="btn btn-primary btn-lg px-4 fw-bold" type="button">
        {{ 'Subscribe'|t }}
      </button>
    </div>

  </div>
</div>
