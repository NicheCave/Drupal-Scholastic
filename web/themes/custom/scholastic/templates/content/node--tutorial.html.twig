<article{{ attributes.addClass('node-tutorial') }}>

  {# ── 1. Hero Header ── #}
  <header class="bg-surface-container-low pt-5 pb-4">
    <div class="container-xl">
      <div class="prose-column mx-auto mx-lg-0 d-flex flex-column gap-3">

        <div class="d-flex align-items-center gap-3">
          {# Category badge — wraps to content, not full width #}
          <div class="d-inline-flex">
            <span class="bg-secondary-container text-on-secondary-container px-3 py-1
                         small fw-semibold rounded-pill text-uppercase font-label"
                  style="letter-spacing:.08em;">
              {{ content.field_category|render|striptags|trim }}
            </span>
          </div>
          <span class="text-on-surface-variant small font-label">
            {{ 'Published'|t }} {{ node.getCreatedTime()|date('F j, Y') }}
          </span>
        </div>

        <h1 class="display-4 fw-bolder font-headline lh-1 mb-0"
            style="color:#001f3c; letter-spacing:-.03em;">
          {{ label }}
        </h1>

        <div class="fs-5 text-on-surface-variant lh-base font-body">
          {{ content.field_subtitle }}
        </div>

      </div>
    </div>
  </header>

  {# ── 2. Main Layout: sidebar + content ── #}
  <div class="container-xl py-5">
    <div class="row g-5">

      <aside class="col-lg-3 d-none d-lg-block">
        <div class="position-sticky" style="top:6rem;">
          {% if content.field_pro_tip|render %}
            <div class="bg-tertiary-container p-4 rounded-3 text-on-tertiary">
              <div class="d-flex align-items-center gap-2 mb-2">
                <span class="fw-bold font-headline">&#128161; {{ 'Pro-Tip'|t }}</span>
              </div>
              <div class="small lh-base opacity-90">
                {{ content.field_pro_tip }}
              </div>
            </div>
          {% endif %}
        </div>
      </aside>

      <div class="col-12 col-lg-9">
        <div class="prose-column mx-auto mx-lg-0 d-flex flex-column gap-5">

          <div class="ratio ratio-16x9 rounded-3 overflow-hidden shadow"
               data-tutorial-img-wrap>
            {{ content.field_hero_image }}
          </div>

          <div class="fs-6 lh-lg text-on-surface-variant">
            {{ content.field_body }}
          </div>

        </div>
      </div>

    </div>
  </div>

</article>
