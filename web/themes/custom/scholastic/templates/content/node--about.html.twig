{% set _ = attach_library('scholastic/node--about') %}
{#
  node--about.html.twig
#}

<article{{ attributes.addClass('node-about') }}>

{# ── 1. HERO ── #}
<section class="bg-white pt-5 pb-4">
  <div class="container-xl">
    <div class="row g-5 align-items-center">

      <div class="col-12 col-lg-6 d-flex flex-column gap-3">

        {% if content.field_eyebrow|render %}
          <span class="d-inline-block small fw-bold text-uppercase text-surface-tint font-label"
                style="letter-spacing:.1em;">
            {{ content.field_eyebrow|render|striptags|trim }}
          </span>
        {% endif %}

        {% if content.field_headline|render %}
          <h1 class="display-5 fw-bolder font-headline lh-sm mb-0"
              style="color:#001f3c; letter-spacing:-.02em;">
            {{ content.field_headline }}
          </h1>
        {% endif %}

        {% if content.field_bio|render %}
          <div class="text-on-surface-variant lh-base font-body" style="max-width:32rem;">
            {{ content.field_bio }}
          </div>
        {% endif %}

      </div>

      <div class="col-12 col-lg-6 position-relative">

        {% if content.field_portrait|render %}
          <div class="rounded-3 overflow-hidden shadow about-portrait-img">
            {{ content.field_portrait }}
          </div>
        {% endif %}

        {% if content.field_stat_number|render %}
          <div class="position-absolute bg-white rounded-3 shadow-lg border p-4"
               style="bottom:-1.5rem; left:-2rem; max-width:14rem;">
            <span class="fw-bolder fs-4 font-headline" style="color:#001f3c;">
              {{ content.field_stat_number }}
              {% if content.field_stat_label|render %}{{ content.field_stat_label }}{% endif %}
            </span>
            {% if content.field_stat_description|render %}
              <span class="d-block small text-on-surface-variant lh-sm mt-1">
                {{ content.field_stat_description }}
              </span>
            {% endif %}
          </div>
        {% endif %}

      </div>
    </div>
  </div>
</section>

{# ── 2. THE JOURNEY ── #}
{% if content.field_journey_body|render %}
<section class="bg-white pt-5 pb-4">
  <div class="container-xl">
    <div class="d-flex flex-column gap-4" style="max-width:38rem;">

      {% if content.field_journey_heading|render %}
        <h2 class="h3 fw-bolder font-headline mb-0" style="color:#001f3c;">
          {{ content.field_journey_heading }}
        </h2>
      {% endif %}

      <div class="text-on-surface-variant lh-base font-body d-flex flex-column gap-3">
        {{ content.field_journey_body }}
      </div>

      {% if content.field_quote|render %}
        <blockquote class="border-start border-4 ps-4 py-3 rounded-end about-pull-quote"
                    style="border-color:#1460a4 !important; background:rgba(20,96,164,.05);">
          <div class="lh-base font-body about-quote-text">
            {{ content.field_quote }}
          </div>
        </blockquote>
      {% endif %}

    </div>
  </div>
</section>
{% endif %}

{# ── 3. CORE EXPERTISE ── #}
{% if content.field_expertise_items|render %}
<section class="bg-surface-container-lowest py-5">
  <div class="container-xl">

    <div class="d-flex flex-column gap-1 mb-4">
      {% if content.field_expertise_heading|render %}
        <h2 class="h3 fw-bolder font-headline mb-0" style="color:#001f3c;">
          {{ content.field_expertise_heading }}
        </h2>
      {% endif %}
      {% if content.field_expertise_subtitle|render %}
        <p class="small text-on-surface-variant font-body mb-0">
          {{ content.field_expertise_subtitle }}
        </p>
      {% endif %}
    </div>

    {# expertise items — hover handled via .about-expertise-grid .sc-expertise-card in node--about.css #}
    <div class="about-expertise-grid" data-eg>
      {{ content.field_expertise_items }}
    </div>

  </div>
</section>
{% endif %}

{# ── 4. HONORS + CTA ── #}
{% if content.field_honors_items|render or content.field_cta_heading|render %}
<section class="bg-white py-5">
  <div class="container-xl">
    <div class="row g-5 align-items-start">

      <div class="col-12 col-lg-6">
        {% if content.field_honors_heading|render %}
          <h2 class="h3 fw-bolder font-headline mb-4" style="color:#001f3c;">
            {{ content.field_honors_heading }}
          </h2>
        {% endif %}
        <div class="about-honors-list d-flex flex-column">
          {{ content.field_honors_items }}
        </div>
      </div>

      {% if content.field_cta_heading|render %}
        <div class="col-12 col-lg-6">
          <div class="rounded-3 p-5 d-flex flex-column gap-4"
               style="background-color:#001f3c;">

            <h3 class="fw-bold font-headline mb-0" style="color:#ffffff;">
              {{ content.field_cta_heading }}
            </h3>

            {% if content.field_cta_body|render %}
              <div class="small lh-base font-body about-cta-body">
                {{ content.field_cta_body }}
              </div>
            {% endif %}

            {% if content.field_cta_url|render %}
              <div class="about-cta-btn">
                {{ content.field_cta_url }}
              </div>
            {% endif %}

          </div>
        </div>
      {% endif %}

    </div>
  </div>
</section>
{% endif %}

</article>
