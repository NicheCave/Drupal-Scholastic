{#
  views-view-unformatted--featured-tutorials.html.twig

  View fields:
    field_hero_image / title / field_subtitle / field_category / view_node
#}

<div class="row g-4">

  {% for row in rows %}

    {% set vsp      = row.content['#view'].style_plugin %}
    {% set idx      = loop.index0 %}
    {% set image    = vsp.getField(idx, 'field_hero_image') %}
    {% set title    = vsp.getField(idx, 'title') %}
    {% set subtitle = vsp.getField(idx, 'field_subtitle') %}
    {% set category = vsp.getField(idx, 'field_category') %}
    {% set path     = vsp.getField(idx, 'view_node') %}

    {# ── Card 1: wide feature card ── #}
    {% if loop.index == 1 %}
    <div class="col-12 col-md-8">
      <div class="position-relative overflow-hidden rounded-3 bg-dark" style="height:450px;">
        <div class="bento-card-img position-absolute top-0 start-0 w-100 h-100"
             style="transition:transform .7s;">
          {{ image }}
        </div>
        <div class="position-absolute top-0 start-0 w-100 h-100"
             style="background:linear-gradient(to top, rgba(0,31,60,.9) 0%, rgba(0,31,60,.2) 60%, transparent 100%); z-index:1;">
        </div>
        <div class="position-absolute bottom-0 start-0 p-4 p-lg-5 text-white" style="z-index:2;">
          <span class="badge bg-tertiary-container text-on-tertiary-container text-uppercase mb-3"
                style="letter-spacing:.08em; font-size:.65rem;">
            {{ category }}
          </span>
          <h3 class="h4 fw-bolder font-headline mb-3 lh-sm">{{ title }}</h3>
          <p class="small mb-4 line-clamp-3" style="color:rgba(191,219,254,.85); max-width:28rem;">{{ subtitle }}</p>
          <a href="{{ path }}" class="d-inline-flex align-items-center gap-2 small fw-bold text-white text-decoration-none">
            {{ 'Start Learning'|t }} &rarr;
          </a>
        </div>
        <a href="{{ path }}" class="position-absolute top-0 start-0 w-100 h-100"
           style="z-index:3;" aria-label="{{ 'Start'|t }} {{ title|striptags }}"></a>
      </div>
    </div>

    {# ── Card 2: narrow split card ── #}
    {% elseif loop.index == 2 %}
    <div class="col-12 col-md-4">
      <div class="position-relative overflow-hidden rounded-3 bg-white border d-flex flex-column"
           style="height:450px;">
        <div class="overflow-hidden" style="height:50%;">
          <div class="bento-card-img w-100 h-100"
               style="transition:transform .5s;">
            {{ image }}
          </div>
        </div>
        <div class="p-4 d-flex flex-column justify-content-between flex-fill">
          <div>
            <span class="badge bg-secondary-container text-on-secondary-container text-uppercase mb-2"
                  style="letter-spacing:.08em; font-size:.65rem;">
              {{ category }}
            </span>
            <h3 class="h5 fw-bold font-headline mb-2" style="color:#001f3c;">{{ title }}</h3>
            <p class="small text-on-surface-variant line-clamp-2 font-body mb-0">{{ subtitle }}</p>
          </div>
          <a href="{{ path }}" class="small fw-bold text-decoration-none d-flex align-items-center gap-1 text-surface-tint">
            {{ 'Read More'|t }} &rsaquo;
          </a>
        </div>
        <a href="{{ path }}" class="position-absolute top-0 start-0 w-100 h-100 rounded-3"
           style="z-index:2;" aria-label="{{ 'Read'|t }} {{ title|striptags }}"></a>
      </div>
    </div>

    {# ── Card 3: icon feature card ── #}
    {% elseif loop.index == 3 %}
    <div class="col-12 col-md-4">
      <div class="position-relative bg-white border rounded-3 p-4 p-lg-5 h-100 d-flex flex-column justify-content-between">
        <div class="bg-secondary-container rounded-circle d-flex align-items-center justify-content-center mb-4"
             style="width:3.5rem; height:3.5rem;">
          <span class="fw-bolder text-surface-tint fs-4">&#9679;</span>
        </div>
        <div>
          <span class="badge bg-secondary-container text-on-secondary-container text-uppercase mb-3"
                style="letter-spacing:.08em; font-size:.65rem;">
            {{ category }}
          </span>
          <h3 class="h5 fw-bold font-headline mb-3" style="color:#001f3c;">{{ title }}</h3>
          <p class="small text-on-surface-variant lh-base font-body mb-0">{{ subtitle }}</p>
        </div>
        <div class="border-top pt-4 mt-4">
          <a href="{{ path }}" class="small fw-bold text-decoration-none d-flex align-items-center gap-1 text-surface-tint">
            {{ 'Start Course'|t }} &rsaquo;
          </a>
        </div>
        <a href="{{ path }}" class="position-absolute top-0 start-0 w-100 h-100 rounded-3"
           style="z-index:2;" aria-label="{{ 'Start'|t }} {{ title|striptags }}"></a>
      </div>
    </div>

    {# ── Card 4: dark horizontal card ── #}
    {% elseif loop.index == 4 %}
    <div class="col-12 col-md-8">
      <div class="position-relative overflow-hidden rounded-3 d-flex flex-column flex-md-row"
           style="background-color:#001f3c; min-height:300px;">
        <div class="p-4 p-lg-5 d-flex flex-column justify-content-center gap-3 flex-fill" style="z-index:1;">
          <span class="badge text-uppercase px-3 py-1"
                style="background:rgba(255,255,255,.12); color:#93c5fd; border:1px solid rgba(255,255,255,.15); letter-spacing:.08em; font-size:.65rem; width:fit-content;">
            {{ category }}
          </span>
          <h3 class="h4 fw-bold font-headline lh-sm mb-0" style="color:#ffffff;">{{ title }}</h3>
          <p class="small line-clamp-3 mb-0" style="color:rgba(191,219,254,.82);">{{ subtitle }}</p>
          <div class="d-inline-flex align-items-center gap-2 fw-bold small rounded px-3 py-2"
               style="background:#ffffff; color:#001f3c; width:fit-content;">
            {{ 'Enroll in Course'|t }} &rarr;
          </div>
        </div>
        <div class="position-relative overflow-hidden flex-shrink-0"
             style="width:100%; height:200px; background:#0f172a;">
          <div class="bento-card-img position-absolute top-0 start-0 w-100 h-100"
               style="transition:transform .7s;">
            {{ image }}
          </div>
          <div class="position-absolute top-0 start-0 w-100 h-100"
               style="background:rgba(0,31,60,.45);"></div>
        </div>
        <a href="{{ path }}" class="position-absolute top-0 start-0 w-100 h-100"
           style="z-index:2;" aria-label="{{ 'Enroll in'|t }} "></a>
      </div>
    </div>

    {# ── Cards 5+: standard split card ── #}
    {% else %}
    <div class="col-12 col-md-4">
      <div class="position-relative overflow-hidden rounded-3 bg-white border d-flex flex-column"
           style="height:350px;">
        <div class="overflow-hidden" style="height:50%;">
          <div class="bento-card-img w-100 h-100">{{ image }}</div>
        </div>
        <div class="p-4 d-flex flex-column justify-content-between flex-fill">
          <div>
            <span class="badge bg-secondary-container text-on-secondary-container text-uppercase mb-2"
                  style="letter-spacing:.08em; font-size:.65rem;">
              {{ category }}
            </span>
            <h3 class="h5 fw-bold font-headline mb-2" style="color:#001f3c;">{{ title }}</h3>
            <p class="small text-on-surface-variant line-clamp-2 font-body mb-0">{{ subtitle }}</p>
          </div>
          <a href="{{ path }}" class="small fw-bold text-decoration-none d-flex align-items-center gap-1 text-surface-tint">
            {{ 'Read More'|t }} &rsaquo;
          </a>
        </div>
        <a href="{{ path }}" class="position-absolute top-0 start-0 w-100 h-100 rounded-3"
           style="z-index:2;" aria-label="{{ 'Read'|t }} {{ title|striptags }}"></a>
      </div>
    </div>
    {% endif %}

  {% endfor %}

</div>
