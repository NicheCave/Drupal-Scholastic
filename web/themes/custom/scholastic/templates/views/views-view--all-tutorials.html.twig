{#
  views-view--all-tutorials.html.twig

  Wraps the entire "All Tutorials" view output:
    header  → view title / description (configured in Views UI)
    rows    → rendered by views-view-unformatted--all-tutorials.html.twig
    pager   → Drupal full pager (styled by pager.html.twig)
#}

{%- if title -%}
  <h2 class="sr-only">{{ title }}</h2>
{%- endif -%}

{# Active filter indicator — shows which category is being filtered #}
{% if exposed %}
  <div class="sr-only">{{ exposed }}</div>
{% endif %}

{# Results count line #}
{% if view_array['#view'].total_rows is defined %}
  <p class="text-sm text-outline font-body mb-6">
    {{ view_array['#view'].total_rows }}
    {{ "tutorials"|t }}
    {% if view_array['#view'].getExposedInput()['field_category_target_id'] is not empty %}
      {{ "in this category"|t }}
    {% endif %}
  </p>
{% endif %}

{# Card grid #}
{% if rows %}
  {{ rows }}
{% elseif empty %}
  <div class="py-20 text-center text-on-surface-variant font-body">
    <span class="material-symbols-outlined text-5xl text-outline mb-4 block">search_off</span>
    {{ empty }}
  </div>
{% endif %}

{# Pager — rendered by pager.html.twig #}
{% if pager %}
  <div class="mt-12 flex justify-center">
    {{ pager }}
  </div>
{% endif %}
