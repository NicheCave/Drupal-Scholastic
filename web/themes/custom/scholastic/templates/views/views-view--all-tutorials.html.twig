{#
  views-view--all-tutorials.html.twig

  Wraps the entire "All Tutorials" view:
    exposed → filter form (hidden visually, still functional)
    rows    → rendered by views-view-unformatted--all-tutorials.html.twig
    pager   → styled by pager.html.twig
#}

{%- if title -%}
  <h2 class="visually-hidden">{{ title }}</h2>
{%- endif -%}

{% if exposed %}
  <div class="visually-hidden">{{ exposed }}</div>
{% endif %}

{# Results count #}
{% if view_array['#view'].total_rows is defined %}
  <p class="small text-muted font-body mb-4">
    {{ view_array['#view'].total_rows }} {{ 'tutorials'|t }}
    {% if view_array['#view'].getExposedInput()['field_category_target_id'] is not empty %}
      {{ 'in this category'|t }}
    {% endif %}
  </p>
{% endif %}

{# Card grid #}
{% if rows %}
  {{ rows }}
{% elseif empty %}
  <div class="py-5 text-center text-on-surface-variant font-body">
    <span class="d-block fs-1 text-muted mb-3">&#128269;</span>
    {{ empty }}
  </div>
{% endif %}

{# Pager #}
{% if pager %}
  <div class="mt-5 d-flex justify-content-center">
    {{ pager }}
  </div>
{% endif %}
