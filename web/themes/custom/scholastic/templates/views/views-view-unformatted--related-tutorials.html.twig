{#
  views-view-unformatted--related-tutorials.html.twig
#}

<section class="bg-surface-container-lowest border-top py-5">
  <div class="container-xl">

    <h2 class="h3 fw-bolder font-headline mb-5" style="color:#001f3c;">
      {{ 'Related Technical Guides'|t }}
    </h2>

    <div class="row row-cols-1 row-cols-md-3 g-4">
      {% for row in rows %}
        {% set node     = row.content['#row']._entity %}
        {% set node_url = path('entity.node.canonical', {'node': node.id}) %}

        <div class="col">
          <article class="position-relative bg-white rounded-3 overflow-hidden border shadow-sm d-flex flex-column h-100">

            <a href="{{ node_url }}"
               class="position-absolute top-0 start-0 w-100 h-100"
               style="z-index:2;"
               aria-label="{{ node.label }}"></a>

            {# Hero image #}
            <div class="ratio ratio-16x9 overflow-hidden bg-surface-container">
              {% if node.field_hero_image.entity %}
                {% set media = node.field_hero_image.entity %}
                {% if media.field_media_image.entity %}
                  <img src="{{ file_url(media.field_media_image.entity.uri.value) }}"
                       alt="{{ media.field_media_image.alt }}"
                       style="width:100%;height:100%;object-fit:cover;transition:transform .3s;">
                {% endif %}
              {% endif %}
            </div>

            {# Card body #}
            <div class="p-4 d-flex flex-column gap-2 flex-fill">

              {% if node.field_category.entity %}
                <div class="badge bg-secondary-container text-on-secondary-container text-uppercase w-auto"
                     style="letter-spacing:.08em; font-size:.65rem; width:fit-content;">
                  {{ node.field_category.entity.label }}
                </div>
              {% endif %}

              <h3 class="h6 fw-bold font-headline lh-sm mb-0" style="color:#001f3c;">
                {{ node.label }}
              </h3>

              {% if node.field_subtitle.value %}
                <p class="small text-on-surface-variant lh-base font-body line-clamp-2 mb-0">
                  {{ node.field_subtitle.value }}
                </p>
              {% endif %}

            </div>
          </article>
        </div>
      {% endfor %}
    </div>

  </div>
</section>
