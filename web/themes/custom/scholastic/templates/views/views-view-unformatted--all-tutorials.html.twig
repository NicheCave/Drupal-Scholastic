{#
  views-view-unformatted--all-tutorials.html.twig
  View fields: field_category / title / field_subtitle / field_read_time
#}

<div class="row row-cols-1 row-cols-md-2 g-4">

  {% for row in rows %}

    {% set vsp         = row.content['#view'].style_plugin %}
    {% set idx         = loop.index0 %}
    {% set node_entity = row.content['#row']._entity %}

    {% set media_entity = node_entity.field_hero_image.entity %}
    {% if media_entity and media_entity.field_media_image is not empty %}
      {% set img_uri = media_entity.field_media_image.entity.uri.value %}
      {% set img_alt = media_entity.field_media_image.alt %}
    {% else %}
      {% set img_uri = null %}
      {% set img_alt = '' %}
    {% endif %}

    {% set title    = vsp.getField(idx, 'title')|striptags|trim %}
    {% set category = vsp.getField(idx, 'field_category')|striptags|trim %}
    {% set subtitle = vsp.getField(idx, 'field_subtitle') %}
    {% set readtime = vsp.getField(idx, 'field_read_time')|striptags|trim %}
    {% set node_url = path('entity.node.canonical', {'node': node_entity.id()}) %}

    <div class="col">
      <article class="position-relative bg-white rounded-3 overflow-hidden border shadow-sm h-100 d-flex flex-column"
               style="transition:box-shadow .3s;">

        {# Hero image — 16:9 #}
        <div class="ratio ratio-16x9 overflow-hidden">
          <div class="bento-card-img w-100 h-100" style="transition:transform .5s;">
            {% if img_uri %}
              <img src="{{ file_url(img_uri) }}" alt="{{ img_alt }}" loading="lazy"
                   style="width:100%;height:100%;object-fit:cover;display:block;">
            {% else %}
              <div class="w-100 h-100 bg-surface-container-high"></div>
            {% endif %}
          </div>
        </div>

        {# Card body #}
        <div class="p-4 d-flex flex-column gap-2 flex-fill">

          {% if category %}
            {# align-self-start prevents flex-column from stretching the badge to full width #}
            <span class="align-self-start badge bg-secondary-container text-on-secondary-container
                         text-uppercase"
                  style="letter-spacing:.08em; font-size:.65rem;">
              {{ category }}
            </span>
          {% endif %}

          <h2 class="h5 fw-bold font-headline lh-sm line-clamp-2 mb-0" style="color:#001f3c;">
            {{ title }}
          </h2>

          {% if subtitle %}
            <p class="small text-on-surface-variant lh-base font-body line-clamp-2 flex-fill mb-0">
              {{ subtitle }}
            </p>
          {% endif %}

          <div class="d-flex align-items-center justify-content-between border-top pt-3 mt-auto">
            {% if readtime %}
              <span class="small text-muted d-flex align-items-center gap-1">
                &#9200; {{ readtime }} {{ 'min read'|t }}
              </span>
            {% else %}
              <span></span>
            {% endif %}
            <span class="small fw-bold text-surface-tint font-body pe-none">
              {{ 'Read More'|t }} &rsaquo;
            </span>
          </div>

        </div>

        <a href="{{ node_url }}"
           class="position-absolute top-0 start-0 w-100 h-100 rounded-3"
           style="z-index:2;"
           aria-label="{{ title }}"></a>

      </article>
    </div>

  {% endfor %}

</div>
