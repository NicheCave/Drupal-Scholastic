{# page--tutorials.html.twig — /tutorials listing page #}

{# ── TOP NAVIGATION ── #}
<header class="sticky-top bg-white shadow-sm">
  <nav class="navbar navbar-expand-md navbar-light py-3">
    <div class="container-xl">
      <a class="navbar-brand fw-bolder fs-5" href="{{ path('<front>') }}" style="color:#001f3c;">
        {{ site_name|striptags }}
      </a>
      <button class="navbar-toggler border-0" type="button"
              data-bs-toggle="collapse" data-bs-target="#mainNavTutorials"
              aria-controls="mainNavTutorials" aria-expanded="false"
              aria-label="{{ 'Toggle navigation'|t }}">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="mainNavTutorials">
        <div class="ms-auto d-flex align-items-center gap-1">
          {{ page.primary_menu }}
          <div class="d-flex align-items-center gap-3 ms-3">
            <form class="d-none d-md-flex align-items-center" role="search"
                  action="{{ path('search.view') }}" method="get">
              <input class="form-control form-control-sm border-0 bg-light rounded-pill"
                     type="search" name="keys"
                     placeholder="{{ 'Search tutorials…'|t }}"
                     style="width:11rem; font-size:.85rem;">
            </form>
            {% if logged_in %}
              <a href="{{ path('user.logout') }}" data-logout-confirm
                 class="btn btn-primary btn-sm px-3 fw-semibold">{{ 'Log Out'|t }}</a>
            {% else %}
              <a href="{{ path('user.login') }}"
                 class="btn btn-primary btn-sm px-3 fw-semibold">{{ 'Sign In'|t }}</a>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </nav>
</header>

{# ── PAGE HEADER ── #}
<div class="bg-white border-bottom">
  <div class="container-xl py-5">
    <h1 class="display-5 fw-bolder font-headline mb-3" style="color:#001f3c;letter-spacing:-.02em;">
      {{ 'The Architectural Library.'|t }}
    </h1>
    <p class="lead text-on-surface-variant font-body mb-0" style="max-width:38rem;">
      {{ 'Master the structural complexity of Drupal through our curated monographs.'|t }}
    </p>
  </div>
</div>

{# ── MAIN LAYOUT ── #}
<main id="main-content" class="bg-surface-container-lowest min-vh-100">
  <div class="container-xl py-5">
    <div class="row g-5 align-items-start">
      <aside class="col-12 col-lg-3">
        <div class="position-sticky" style="top:5rem;">
          {{ page.sidebar_first }}
        </div>
      </aside>
      <div class="col-12 col-lg-9">
        {{ page.content }}
      </div>
    </div>
  </div>
</main>

{# ── FOOTER ── #}
<footer class="bg-surface-container-lowest border-top">
  <div class="container-xl py-5">
    <div class="row g-5">
      <div class="col-12 col-md-4">
        <a href="{{ path('<front>') }}" class="text-decoration-none d-flex align-items-center gap-2 mb-3">
          {% if logo %}<img src="{{ logo }}" alt="{{ site_name }}" style="height:1.75rem;width:auto;">
          {% else %}<span class="fw-bolder fs-5 font-headline" style="color:#001f3c;">{{ site_name }}</span>{% endif %}
        </a>
        {% if site_slogan %}<p class="small text-on-surface-variant mb-2">{{ site_slogan }}</p>{% endif %}
        <p class="small text-muted mb-0">&copy; {{ "now"|date("Y") }} {{ site_name }}. {{ 'An Architectural Approach to Learning.'|t }}</p>
      </div>
      <div class="col-12 col-md-5">
        <div class="row g-4">
          <div class="col-6">
            <h6 class="text-uppercase fw-bold small mb-3 font-headline" style="color:#001f3c;letter-spacing:.1em;">{{ 'Explore'|t }}</h6>
            {{ page.footer }}
          </div>
          <div class="col-6">
            <h6 class="text-uppercase fw-bold small mb-3 font-headline" style="color:#001f3c;letter-spacing:.1em;">{{ 'Legal'|t }}</h6>
            <ul class="list-unstyled mb-0">
              <li><a href="/privacy" class="small text-on-surface-variant text-decoration-none d-block py-1">{{ 'Privacy Policy'|t }}</a></li>
              <li><a href="/terms" class="small text-on-surface-variant text-decoration-none d-block py-1">{{ 'Terms of Service'|t }}</a></li>
              <li><a href="/contact" class="small text-on-surface-variant text-decoration-none d-block py-1">{{ 'Contact Support'|t }}</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-3 d-flex flex-column align-items-md-end">
        <div class="d-flex gap-2">
          <a href="#" class="d-flex align-items-center justify-content-center rounded-circle text-muted border" style="width:2.5rem;height:2.5rem;">&#8599;</a>
          <a href="#" class="d-flex align-items-center justify-content-center rounded-circle text-muted border" style="width:2.5rem;height:2.5rem;">@</a>
          <a href="#" class="d-flex align-items-center justify-content-center rounded-circle text-muted border" style="width:2.5rem;height:2.5rem;">&#9675;</a>
        </div>
      </div>
    </div>
  </div>
</footer>
