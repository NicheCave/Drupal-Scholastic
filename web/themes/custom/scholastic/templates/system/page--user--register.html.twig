<div class="min-h-screen grid grid-cols-1 lg:grid-cols-2">

  {# ── Left Panel: Branded hero ── #}
  <div class="hidden lg:flex flex-col justify-between hero-gradient p-16 relative overflow-hidden">

    {# Decorative shapes #}
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/5 rounded-full translate-y-1/3 -translate-x-1/3"></div>
    <div class="absolute top-1/2 left-1/2 w-48 h-48 bg-surface-tint/20 rounded-full -translate-x-1/2 -translate-y-1/2 blur-2xl"></div>

    {# Logo #}
    <a href="/" class="no-underline">
      <div class="text-2xl font-extrabold tracking-tighter text-white font-headline relative z-10">
        Drupal Scholastic
      </div>
    </a>

    {# Central copy — different from login to match the "join" intent #}
    <div class="relative z-10">
      <span class="inline-block py-1 px-3 bg-white/10 text-blue-200 text-xs font-bold tracking-widest uppercase mb-6 rounded">
        Join the Community
      </span>
      <h2 class="text-4xl font-extrabold text-white font-headline leading-tight mb-4">
        Start your<br>architectural journey.
      </h2>
      <p class="text-blue-100/80 text-base leading-relaxed max-w-xs font-body">
        Get access to expert tutorials, structural deep-dives, and a community of Drupal developers.
      </p>
    </div>

    {# Social proof #}
    <div class="relative z-10">
      <div class="flex -space-x-3 mb-4">
        <div class="w-10 h-10 rounded-full border-2 border-primary bg-slate-300"></div>
        <div class="w-10 h-10 rounded-full border-2 border-primary bg-slate-400"></div>
        <div class="w-10 h-10 rounded-full border-2 border-primary bg-slate-500"></div>
        <div class="w-10 h-10 rounded-full border-2 border-primary bg-slate-600 flex items-center justify-center">
          <span class="text-white text-xs font-bold">+</span>
        </div>
      </div>
      <p class="text-blue-100/70 text-sm font-body">
        Join <span class="text-white font-semibold">20,000+</span> developers already enrolled.
      </p>
    </div>

  </div>

  {# ── Right Panel: Register form ── #}
  <div class="flex flex-col justify-center items-center bg-surface px-8 py-16 lg:px-16">

    {# Mobile-only logo #}
    <a href="/" class="lg:hidden no-underline mb-10">
      <div class="text-xl font-extrabold tracking-tighter text-primary font-headline">Drupal Scholastic</div>
    </a>

    <div class="w-full max-w-sm">

      {# Header #}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold text-primary font-headline mb-2">Create your account</h1>
        <p class="text-sm text-on-surface-variant font-body">Free to join. Start learning immediately.</p>
      </div>

      {# Drupal injects the registration form here #}
      <div class="drupal-form-wrapper">
        {{ page.content }}
      </div>

      {# Footer link #}
      <div class="mt-8 pt-8 border-t border-surface-container-high text-center text-sm text-on-surface-variant font-body">
        Already have an account?
        <a href="/user/login" class="text-surface-tint font-semibold hover:underline no-underline ml-1">
          Sign in →
        </a>
      </div>

    </div>

    {# Back to home #}
    <a href="/" class="mt-12 flex items-center gap-2 text-xs text-on-surface-variant hover:text-primary transition-colors no-underline font-body">
      <span class="material-symbols-outlined" style="font-size:16px;">arrow_back</span>
      Back to home
    </a>

  </div>

</div>
