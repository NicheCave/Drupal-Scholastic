{#
  page--user--register.html.twig
#}
{% set _ = attach_library('scholastic/page--user-auth') %}

<div class="min-vh-100 row g-0">

  {# ── Left panel: branded hero (desktop only) ── #}
  <div class="col-lg-6 d-none d-lg-flex flex-column justify-content-between hero-gradient p-5 position-relative overflow-hidden">

    <div class="position-absolute rounded-circle" style="width:24rem;height:24rem;background:rgba(255,255,255,.05);top:0;right:0;transform:translate(50%,-50%);"></div>
    <div class="position-absolute rounded-circle" style="width:16rem;height:16rem;background:rgba(255,255,255,.05);bottom:0;left:0;transform:translate(-50%,33%);"></div>

    <a href="/" class="text-decoration-none position-relative" style="z-index:1;">
      <span class="fw-bolder fs-4 text-white font-headline">Drupal Scholastic</span>
    </a>

    <div class="position-relative" style="z-index:1;">
      <span class="badge px-3 py-2 mb-4 d-inline-block"
            style="background:rgba(255,255,255,.1); color:#93c5fd; letter-spacing:.1em; font-size:.7rem;">
        {{ 'Join the Community'|t }}
      </span>
      <h2 class="display-6 fw-bolder text-white font-headline lh-sm mb-3">
        {{ 'Start your'|t }}<br>{{ 'architectural journey.'|t }}
      </h2>
      <p class="font-body mb-0" style="color:rgba(191,219,254,.8); max-width:20rem;">
        {{ 'Get access to expert tutorials, structural deep-dives, and a community of Drupal developers.'|t }}
      </p>
    </div>

    {# Social proof #}
    <div class="position-relative" style="z-index:1;">
      <div class="d-flex mb-3" style="gap:-.75rem;">
        <div class="rounded-circle border border-2 border-primary bg-secondary" style="width:2.5rem;height:2.5rem;"></div>
        <div class="rounded-circle border border-2 border-primary bg-secondary" style="width:2.5rem;height:2.5rem;margin-left:-.75rem;"></div>
        <div class="rounded-circle border border-2 border-primary bg-secondary-subtle" style="width:2.5rem;height:2.5rem;margin-left:-.75rem;"></div>
        <div class="rounded-circle border border-2 border-primary bg-secondary d-flex align-items-center justify-content-center" style="width:2.5rem;height:2.5rem;margin-left:-.75rem;">
          <span class="text-white small fw-bold">+</span>
        </div>
      </div>
      <p class="small mb-0" style="color:rgba(191,219,254,.7);">
        {{ 'Join'|t }} <span class="text-white fw-semibold">20,000+</span> {{ 'developers already enrolled.'|t }}
      </p>
    </div>

  </div>

  {# ── Right panel: register form ── #}
  <div class="col-12 col-lg-6 d-flex flex-column justify-content-center align-items-center bg-light px-4 py-5 px-lg-5">

    <a href="/" class="d-lg-none text-decoration-none mb-5">
      <span class="fw-bolder fs-5 font-headline" style="color:#001f3c;">Drupal Scholastic</span>
    </a>

    <div class="w-100" style="max-width:22rem;">

      <div class="mb-5">
        <h1 class="h3 fw-bolder font-headline mb-1" style="color:#001f3c;">{{ 'Create your account'|t }}</h1>
        <p class="small text-muted font-body mb-0">{{ 'Free to join. Start learning immediately.'|t }}</p>
      </div>

      <div class="drupal-form-wrapper">
        {{ page.content }}
      </div>

      <div class="mt-4 pt-4 border-top text-center small text-muted font-body">
        {{ 'Already have an account?'|t }}
        <a href="/user/login" class="fw-semibold text-decoration-none ms-1 text-surface-tint">{{ 'Sign in'|t }} &rarr;</a>
      </div>

    </div>

    <a href="/" class="d-flex align-items-center gap-2 mt-5 small text-muted text-decoration-none font-body">
      &larr; {{ 'Back to home'|t }}
    </a>

  </div>

</div>
