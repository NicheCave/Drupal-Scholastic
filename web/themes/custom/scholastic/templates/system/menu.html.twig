<ul class="flex flex-row items-center gap-8 list-none p-0 m-0">
  {% for item in items %}
    <li class="m-0 p-0 flex items-center">
      <a href="{{ item.url }}" 
         class="relative text-[15px] font-semibold font-body no-underline pb-1 transition-colors duration-300
                
                {# ACTIVE STATE #}
                {% if item.in_active_trail %}
                  text-surface-tint after:w-full
                
                {# INACTIVE STATE #}
                {% else %}
                  text-on-surface-variant hover:text-surface-tint after:w-0 hover:after:w-full
                {% endif %}
                
                {# ANIMATED UNDERLINE #}
                after:absolute after:bottom-0 after:left-0 after:h-[2px] 
                after:bg-surface-tint after:transition-all after:duration-300">
        {{ item.title }}
      </a>
      
    </li>
  {% endfor %}
</ul>