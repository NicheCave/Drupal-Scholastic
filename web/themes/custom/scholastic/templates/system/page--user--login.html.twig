{#
  page--user--login.html.twig
#}
{% set _ = attach_library('scholastic/page--user-auth') %}

<div class="min-vh-100 row g-0">

  {# ── Left panel: branded hero (desktop only) ── #}
  <div class="col-lg-6 d-none d-lg-flex flex-column justify-content-between hero-gradient p-5 position-relative overflow-hidden">

    {# Decorative shapes #}
    <div class="position-absolute rounded-circle" style="width:24rem;height:24rem;background:rgba(255,255,255,.05);top:0;right:0;transform:translate(50%,-50%);"></div>
    <div class="position-absolute rounded-circle" style="width:16rem;height:16rem;background:rgba(255,255,255,.05);bottom:0;left:0;transform:translate(-50%,33%);"></div>

    {# Logo #}
    <a href="/" class="text-decoration-none position-relative" style="z-index:1;">
      <span class="fw-bolder fs-4 text-white font-headline">Drupal Scholastic</span>
    </a>

    {# Central copy #}
    <div class="position-relative" style="z-index:1;">
      <span class="badge px-3 py-2 mb-4 d-inline-block"
            style="background:rgba(255,255,255,.1); color:#93c5fd; letter-spacing:.1em; font-size:.7rem;">
        {{ 'The Architectural Monograph'|t }}
      </span>
      <h2 class="display-6 fw-bolder text-white font-headline lh-sm mb-3">
        Master Drupal.<br>Build What Lasts.
      </h2>
      <p class="font-body mb-0" style="color:rgba(191,219,254,.8); max-width:20rem;">
        {{ 'Join thousands of developers learning to build resilient, high-performance digital experiences.'|t }}
      </p>
    </div>

    {# Feature pills #}
    <div class="d-flex flex-wrap gap-2 position-relative" style="z-index:1;">
      <span class="d-flex align-items-center gap-2 rounded-pill px-3 py-2 small"
            style="background:rgba(255,255,255,.1); color:rgba(191,219,254,.9);">
        &#9723; {{ 'Modular Design'|t }}
      </span>
      <span class="d-flex align-items-center gap-2 rounded-pill px-3 py-2 small"
            style="background:rgba(255,255,255,.1); color:rgba(191,219,254,.9);">
        &#128274; {{ 'Enterprise Security'|t }}
      </span>
      <span class="d-flex align-items-center gap-2 rounded-pill px-3 py-2 small"
            style="background:rgba(255,255,255,.1); color:rgba(191,219,254,.9);">
        &#9889; {{ 'Unmatched Speed'|t }}
      </span>
    </div>

  </div>

  {# ── Right panel: login form ── #}
  <div class="col-12 col-lg-6 d-flex flex-column justify-content-center align-items-center bg-light px-4 py-5 px-lg-5">

    {# Mobile-only logo #}
    <a href="/" class="d-lg-none text-decoration-none mb-5">
      <span class="fw-bolder fs-5 font-headline" style="color:#001f3c;">Drupal Scholastic</span>
    </a>

    <div class="w-100" style="max-width:22rem;">

      <div class="mb-5">
        <h1 class="h3 fw-bolder font-headline mb-1" style="color:#001f3c;">{{ 'Welcome back'|t }}</h1>
        <p class="small text-muted font-body mb-0">{{ 'Sign in to continue your learning journey.'|t }}</p>
      </div>

      {# Bootstrap styles Drupal's form fields via form-control automatically #}
      <div class="drupal-form-wrapper">
        {{ page.content }}
      </div>

      <div class="d-flex align-items-center justify-content-between mt-4 pt-4 border-top small">
        <a href="/user/password" class="text-surface-tint text-decoration-none font-body">{{ 'Forgot password?'|t }}</a>
        <a href="/user/register" class="fw-semibold text-decoration-none font-body" style="color:#001f3c;">{{ 'Create account'|t }} &rarr;</a>
      </div>

    </div>

    <a href="/" class="d-flex align-items-center gap-2 mt-5 small text-muted text-decoration-none font-body">
      &larr; {{ 'Back to home'|t }}
    </a>

  </div>

</div>
