<div class="min-h-screen grid grid-cols-1 lg:grid-cols-2">

  {# Left Panel: Branded hero #}
  <div class="hidden lg:flex flex-col justify-between hero-gradient p-16 relative overflow-hidden">

    {# Decorative geometric shapes #}
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/5 rounded-full translate-y-1/3 -translate-x-1/3"></div>
    <div class="absolute top-1/2 left-1/2 w-48 h-48 bg-surface-tint/20 rounded-full -translate-x-1/2 -translate-y-1/2 blur-2xl"></div>

    {# Logo #}
    <a href="/" class="no-underline">
      <div class="text-2xl font-extrabold tracking-tighter text-white font-headline relative z-10">
        Drupal Scholastic
      </div>
    </a>

    {# Central copy #}
    <div class="relative z-10">
      <span class="inline-block py-1 px-3 bg-white/10 text-blue-200 text-xs font-bold tracking-widest uppercase mb-6 rounded">
        The Architectural Monograph
      </span>
      <h2 class="text-4xl font-extrabold text-white font-headline leading-tight mb-4">
        Master Drupal.<br>Build What Lasts.
      </h2>
      <p class="text-blue-100/80 text-base leading-relaxed max-w-xs font-body">
        Join thousands of developers learning to build resilient, high-performance digital experiences.
      </p>
    </div>

    {# Feature pills at bottom #}
    <div class="relative z-10 flex flex-wrap gap-3">
      <div class="flex items-center gap-2 bg-white/10 rounded-full px-4 py-2">
        <span class="material-symbols-outlined text-blue-200 text-base" style="font-size:16px;">architecture</span>
        <span class="text-xs text-blue-100 font-medium font-body">Modular Design</span>
      </div>
      <div class="flex items-center gap-2 bg-white/10 rounded-full px-4 py-2">
        <span class="material-symbols-outlined text-blue-200 text-base" style="font-size:16px;">security</span>
        <span class="text-xs text-blue-100 font-medium font-body">Enterprise Security</span>
      </div>
      <div class="flex items-center gap-2 bg-white/10 rounded-full px-4 py-2">
        <span class="material-symbols-outlined text-blue-200 text-base" style="font-size:16px;">speed</span>
        <span class="text-xs text-blue-100 font-medium font-body">Unmatched Speed</span>
      </div>
    </div>

  </div>

  {# Right Panel: Login form #}
  <div class="flex flex-col justify-center items-center bg-surface px-8 py-16 lg:px-16">

    {# Mobile-only logo #}
    <a href="/" class="lg:hidden no-underline mb-10">
      <div class="text-xl font-extrabold tracking-tighter text-primary font-headline">Drupal Scholastic</div>
    </a>

    <div class="w-full max-w-sm">

      {# Header #}
      <div class="mb-10">
        <h1 class="text-3xl font-extrabold text-primary font-headline mb-2">Welcome back</h1>
        <p class="text-sm text-on-surface-variant font-body">Sign in to continue your learning journey.</p>
      </div>

      {# Drupal injects the login form here #}
      <div class="drupal-form-wrapper">
        {{ page.content }}
      </div>

      {# Footer links #}
      <div class="mt-8 pt-8 border-t border-surface-container-high flex items-center justify-between text-sm">
        <a href="/user/password" class="text-surface-tint font-medium hover:underline no-underline font-body">
          Forgot password?
        </a>
        <a href="/user/register" class="text-primary font-semibold hover:text-surface-tint transition-colors no-underline font-body">
          Create account →
        </a>
      </div>

    </div>

    {# Back to home #}
    <a href="/" class="mt-12 flex items-center gap-2 text-xs text-on-surface-variant hover:text-primary transition-colors no-underline font-body">
      <span class="material-symbols-outlined" style="font-size:16px;">arrow_back</span>
      Back to home
    </a>

  </div>

</div>
