<!DOCTYPE html>
<html{{ html_attributes }}>
  <head>
    <head-placeholder token="{{ placeholder_token|raw }}">
    <title>{{ head_title|safe_join(' | ') }}</title>
    <css-placeholder token="{{ placeholder_token|raw }}">
    <js-placeholder token="{{ placeholder_token|raw }}">

    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

    {#
      Tailwind CDN is loaded here as a plain blocking <script> tag so the
      browser executes it immediately. The config <script> directly below is
      guaranteed to run after — tailwind.config (not window.tailwind.config)
      is the correct property name for Tailwind v3 CDN.
      This replaces the libraries.yml approach which could not guarantee order.
    #}
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              /* ── Blue-Navy primary ── */
              "primary":                   "#001f3c",
              "primary-container":         "#00345f",
              "on-primary":                "#ffffff",
              "on-primary-container":      "#629fe6",
              "primary-fixed":             "#d3e4ff",
              "primary-fixed-dim":         "#a1c9ff",
              "on-primary-fixed":          "#001c38",
              "on-primary-fixed-variant":  "#004880",
              "inverse-primary":           "#a1c9ff",

              /* ── Slate secondary ── */
              "secondary":                 "#526070",
              "secondary-container":       "#d5e4f7",
              "on-secondary":              "#ffffff",
              "on-secondary-container":    "#586676",
              "secondary-fixed":           "#d5e4f7",
              "secondary-fixed-dim":       "#b9c8da",
              "on-secondary-fixed":        "#0e1d2a",
              "on-secondary-fixed-variant":"#3a4857",

              /* ── Warm tertiary ── */
              "tertiary":                  "#381300",
              "tertiary-container":        "#592300",
              "on-tertiary":               "#ffffff",
              "on-tertiary-container":     "#d8885c",
              "tertiary-fixed":            "#ffdbca",
              "tertiary-fixed-dim":        "#ffb690",
              "on-tertiary-fixed":         "#341100",
              "on-tertiary-fixed-variant": "#723610",

              /* ── Surfaces ── */
              "surface":                   "#f8f9fa",
              "surface-dim":               "#d9dadb",
              "surface-bright":            "#f8f9fa",
              "surface-container-lowest":  "#ffffff",
              "surface-container-low":     "#f3f4f5",
              "surface-container":         "#edeeef",
              "surface-container-high":    "#e7e8e9",
              "surface-container-highest": "#e1e3e4",
              "surface-variant":           "#e1e3e4",
              "surface-tint":              "#1460a4",
              "on-surface":                "#191c1d",
              "on-surface-variant":        "#43474f",

              /* ── Background ── */
              "background":                "#f8f9fa",
              "on-background":             "#191c1d",

              /* ── Outline ── */
              "outline":                   "#737780",
              "outline-variant":           "#c3c6d1",

              /* ── Inverse ── */
              "inverse-surface":           "#2e3132",
              "inverse-on-surface":        "#f0f1f2",

              /* ── Error ── */
              "error":                     "#ba1a1a",
              "error-container":           "#ffdad6",
              "on-error":                  "#ffffff",
              "on-error-container":        "#93000a",
            },
            fontFamily: {
              "headline": ["Manrope",  "sans-serif"],
              "body":     ["Inter",    "sans-serif"],
              "label":    ["Inter",    "sans-serif"],
            },
            borderRadius: {
              DEFAULT: "0.125rem",
              lg:      "0.25rem",
              xl:      "0.5rem",
              full:    "0.75rem",
            },
          },
        },
      };

      /* Reveal page once Tailwind has processed classes */
      document.addEventListener("DOMContentLoaded", () => {
        document.body.removeAttribute("data-tailwind-cloak");
      });
    </script>

    <style>
      /* ── Material Symbols icon weight ── */
      .material-symbols-outlined {
        font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
      }

      /* ── Reading column max-width ── */
      .prose-column { max-width: 680px; }

      /* ── Page-cloak: hide unstyled flash ── */
      [data-tailwind-cloak] { opacity: 0; }

      /* ═══════════════════════════════════════════════════════════════
         FEATURE GRID FIX
         Problem: {{ content.field_features }} renders Drupal's
         .field  >  .field__items  >  .field__item  wrappers.
         Those block-level divs sit between the CSS-grid container
         and the actual paragraph items, so grid columns never form.
         Fix: display:contents makes those wrappers invisible to the
         layout engine — .field__item becomes a direct grid child.
      ═══════════════════════════════════════════════════════════════ */
      [data-feature-grid] .field--name-field-features,
      [data-feature-grid] .field--name-field-features .field__items {
        display: contents;
      }
      /* Each paragraph item fills its grid cell fully */
      [data-feature-grid] .field--name-field-features .field__item {
        display: flex;
        flex-direction: column;
      }
      [data-feature-grid] .field--name-field-features .field__item > * {
        flex: 1;
      }

      /* ═══════════════════════════════════════════════════════════════
         HERO IMAGE FIX
         Problem: {{ content.field_hero_image }} wraps the <img> in
         multiple Drupal divs (.field, .field__items, .field__item,
         .media, .media__element). Any wrapper with height:auto
         collapses the image to zero height.
         Fix: target them via [data-hero-img-wrap] — a custom
         attribute we put on the hero image container in the block
         template, so we never have to guess Drupal's generated classes.
      ═══════════════════════════════════════════════════════════════ */
      [data-hero-img-wrap],
      [data-hero-img-wrap] > *,
      [data-hero-img-wrap] .field,
      [data-hero-img-wrap] .field__items,
      [data-hero-img-wrap] .field__item,
      [data-hero-img-wrap] .media,
      [data-hero-img-wrap] .media__element,
      [data-hero-img-wrap] a {
        display: block;
        width:   100%;
        height:  100%;
      }
      [data-hero-img-wrap] img {
        display:    block;
        width:      100%;
        height:     100%;
        object-fit: cover;
        object-position: center;
      }

      /* ── Bento-grid card images (Views) ── */
      .bento-card-img,
      .bento-card-img > *,
      .bento-card-img .field,
      .bento-card-img .field__items,
      .bento-card-img .field__item,
      .bento-card-img .media,
      .bento-card-img .media__element,
      .bento-card-img a {
        display: block;
        width:   100%;
        height:  100%;
      }
      .bento-card-img img {
        display:    block;
        width:      100%;
        height:     100%;
        object-fit: cover;
      }

      /* ═══════════════════════════════════════════════════════════════
         DRUPAL FORM STYLES (login / register / logout pages)
      ═══════════════════════════════════════════════════════════════ */
      input[type="text"],
      input[type="password"],
      input[type="email"],
      input[type="tel"],
      select,
      textarea {
        display: block;
        width: 100%;
        padding: 0.75rem 1rem;
        margin-top: 0.375rem;
        margin-bottom: 1.25rem;
        border: 1px solid #e7e8e9;
        border-radius: 0.5rem;
        background-color: #ffffff;
        color: #191c1d;
        font-family: "Inter", sans-serif;
        font-size: 0.9375rem;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      input:focus, select:focus, textarea:focus {
        outline: none;
        border-color: #1460a4;
        box-shadow: 0 0 0 3px rgba(20, 96, 164, 0.12);
      }
      label {
        display: block;
        font-weight: 600;
        font-size: 0.875rem;
        color: #001f3c;
        margin-bottom: 0.25rem;
        font-family: "Inter", sans-serif;
      }
      .form-submit {
        display: block;
        width: 100%;
        padding: 0.875rem 1.5rem;
        margin-top: 0.5rem;
        background-color: #001f3c;
        color: #ffffff;
        font-weight: 700;
        font-family: "Inter", sans-serif;
        font-size: 0.9375rem;
        border: none;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: opacity 0.15s;
        letter-spacing: 0.01em;
      }
      .form-submit:hover { opacity: 0.88; }

      /* ── Footer menu override: Drupal renders <ul> in footer region ── */
      footer nav ul,
      .region-footer ul {
        list-style: none;
        margin:  0;
        padding: 0;
      }
      footer nav ul li a,
      .region-footer ul li a {
        display: block;
        font-size: 0.875rem;
        color: #43474f;
        text-decoration: none;
        padding: 0.25rem 0;
        transition: color 0.15s;
      }
      footer nav ul li a:hover,
      .region-footer ul li a:hover { color: #001f3c; }

      /* ── Gradient helper (used by hero CTA + auth pages) ── */
      .hero-gradient {
        background: linear-gradient(135deg, #001f3c 0%, #00345f 100%);
      }

      [data-tutorial-img-wrap],
      [data-tutorial-img-wrap] > *,
      [data-tutorial-img-wrap] .field,
      [data-tutorial-img-wrap] .field__items,
      [data-tutorial-img-wrap] .field__item,
      [data-tutorial-img-wrap] .media,
      [data-tutorial-img-wrap] .media__element,
      [data-tutorial-img-wrap] a {
        display: block;
        width:   100%;
        height:  100%;
      }
      [data-tutorial-img-wrap] img {
        display:    block;
        width:      100%;
        height:     100%;
        object-fit: cover;
        object-position: center;
      }
    </style>
  </head>

  <body{{ attributes.addClass("bg-surface", "font-body", "text-on-surface").setAttribute("data-tailwind-cloak", "") }}>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] bg-primary text-on-primary px-4 py-2 rounded font-semibold">
      {{ "Skip to main content"|t }}
    </a>
    {{ page_top }}
    {{ page }}
    {{ page_bottom }}
    <js-bottom-placeholder token="{{ placeholder_token|raw }}">
  </body>
</html>
