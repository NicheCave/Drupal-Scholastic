<!DOCTYPE html>
<html{{ html_attributes }}>
  <head>
    <head-placeholder token="{{ placeholder_token|raw }}">
    <title>{{ head_title|safe_join(' | ') }}</title>
    <css-placeholder token="{{ placeholder_token|raw }}">
    <js-placeholder token="{{ placeholder_token|raw }}">

    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              /* ── Blue-Navy primary ── */
              "primary":                   "#001f3c",
              "primary-container":         "#00345f",
              "on-primary":                "#ffffff",
              "on-primary-container":      "#629fe6",
              "primary-fixed":             "#d3e4ff",
              "primary-fixed-dim":         "#a1c9ff",
              "on-primary-fixed":          "#001c38",
              "on-primary-fixed-variant":  "#004880",
              "inverse-primary":           "#a1c9ff",

              /* ── Slate secondary ── */
              "secondary":                 "#526070",
              "secondary-container":       "#d5e4f7",
              "on-secondary":              "#ffffff",
              "on-secondary-container":    "#586676",
              "secondary-fixed":           "#d5e4f7",
              "secondary-fixed-dim":       "#b9c8da",
              "on-secondary-fixed":        "#0e1d2a",
              "on-secondary-fixed-variant":"#3a4857",

              /* ── Warm tertiary ── */
              "tertiary":                  "#381300",
              "tertiary-container":        "#592300",
              "on-tertiary":               "#ffffff",
              "on-tertiary-container":     "#d8885c",
              "tertiary-fixed":            "#ffdbca",
              "tertiary-fixed-dim":        "#ffb690",
              "on-tertiary-fixed":         "#341100",
              "on-tertiary-fixed-variant": "#723610",

              /* ── Surfaces ── */
              "surface":                   "#f8f9fa",
              "surface-dim":               "#d9dadb",
              "surface-bright":            "#f8f9fa",
              "surface-container-lowest":  "#ffffff",
              "surface-container-low":     "#f3f4f5",
              "surface-container":         "#edeeef",
              "surface-container-high":    "#e7e8e9",
              "surface-container-highest": "#e1e3e4",
              "surface-variant":           "#e1e3e4",
              "surface-tint":              "#1460a4",
              "on-surface":                "#191c1d",
              "on-surface-variant":        "#43474f",

              /* ── Background ── */
              "background":                "#f8f9fa",
              "on-background":             "#191c1d",

              /* ── Outline ── */
              "outline":                   "#737780",
              "outline-variant":           "#c3c6d1",

              /* ── Inverse ── */
              "inverse-surface":           "#2e3132",
              "inverse-on-surface":        "#f0f1f2",

              /* ── Error ── */
              "error":                     "#ba1a1a",
              "error-container":           "#ffdad6",
              "on-error":                  "#ffffff",
              "on-error-container":        "#93000a",
            },
            fontFamily: {
              "headline": ["Manrope",  "sans-serif"],
              "body":     ["Inter",    "sans-serif"],
              "label":    ["Inter",    "sans-serif"],
            },
            borderRadius: {
              DEFAULT: "0.125rem",
              lg:      "0.25rem",
              xl:      "0.5rem",
              full:    "0.75rem",
            },
          },
        },
      };

      /* Reveal page once Tailwind has processed classes */
      document.addEventListener("DOMContentLoaded", () => {
        document.body.removeAttribute("data-tailwind-cloak");
      });
    </script>
  </head>

  <body{{ attributes.addClass("bg-surface", "font-body", "text-on-surface").setAttribute("data-tailwind-cloak", "") }}>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] bg-primary text-on-primary px-4 py-2 rounded font-semibold">
      {{ "Skip to main content"|t }}
    </a>
    {{ page_top }}
    {{ page }}
    {{ page_bottom }}
    <js-bottom-placeholder token="{{ placeholder_token|raw }}">

    {# LOGOUT CONFIRMATION MODAL #}
    <div id="logout-modal-backdrop"
         aria-modal="true" role="dialog" aria-labelledby="logout-modal-title"
         style="display:none; position:fixed; inset:0; z-index:9999;
                background:rgba(0,0,0,0.45); backdrop-filter:blur(4px);
                -webkit-backdrop-filter:blur(4px);
                align-items:center; justify-content:center;">

      <div id="logout-modal-card"
           style="background:#ffffff; border-radius:16px; padding:40px 36px 32px;
                  width:100%; max-width:400px; margin:16px;
                  box-shadow:0 24px 60px rgba(0,31,60,0.18), 0 4px 16px rgba(0,31,60,0.10);
                  transform:scale(0.94) translateY(12px);
                  opacity:0;
                  transition:transform 0.22s cubic-bezier(0.34,1.36,0.64,1),
                              opacity 0.18s ease;
                  font-family:'Inter',sans-serif;">

        {# Icon #}
        <div style="width:52px; height:52px; border-radius:14px;
                    background:#f3f4f5; display:flex; align-items:center;
                    justify-content:center; margin-bottom:20px;">
          <span class="material-symbols-outlined"
                style="font-size:26px; color:#001f3c;
                       font-variation-settings:'FILL' 0,'wght' 300,'GRAD' 0,'opsz' 24;">
            logout
          </span>
        </div>

        {# Heading #}
        <h2 id="logout-modal-title"
            style="margin:0 0 8px; font-family:'Manrope',sans-serif;
                   font-size:1.25rem; font-weight:800; color:#001f3c;
                   letter-spacing:-0.01em; line-height:1.3;">
          Log out?
        </h2>

        {# Body copy #}
        <p style="margin:0 0 28px; font-size:0.9375rem; color:#43474f;
                  line-height:1.6;">
          You'll be signed out of your account. Any unsaved progress will be lost.
        </p>

        {# Buttons #}
        <div style="display:flex; flex-direction:column; gap:10px;">
          <button id="logout-modal-confirm"
                  style="width:100%; padding:13px 20px;
                         background:#001f3c; color:#ffffff;
                         font-family:'Inter',sans-serif; font-weight:700;
                         font-size:0.9375rem; border:none; border-radius:10px;
                         cursor:pointer; letter-spacing:0.01em;
                         transition:opacity 0.15s, transform 0.1s;">
            Yes, log out
          </button>
          <button id="logout-modal-cancel"
                  style="width:100%; padding:13px 20px;
                         background:#f3f4f5; color:#001f3c;
                         font-family:'Inter',sans-serif; font-weight:600;
                         font-size:0.9375rem; border:none; border-radius:10px;
                         cursor:pointer;
                         transition:background 0.15s, transform 0.1s;">
            Cancel
          </button>
        </div>

      </div>
    </div>

    <script>
    (function () {
      var backdrop = document.getElementById('logout-modal-backdrop');
      var card     = document.getElementById('logout-modal-card');
      var confirmBtn = document.getElementById('logout-modal-confirm');
      var cancelBtn  = document.getElementById('logout-modal-cancel');
      var pendingHref = null;

      function openModal(href) {
        pendingHref = href;
        backdrop.style.display = 'flex';
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            card.style.transform = 'scale(1) translateY(0)';
            card.style.opacity   = '1';
          });
        });
        confirmBtn.focus();
      }

      function closeModal() {
        card.style.transform = 'scale(0.94) translateY(12px)';
        card.style.opacity   = '0';
        setTimeout(function () {
          backdrop.style.display = 'none';
          pendingHref = null;
        }, 200);
      }

      /* Intercept all logout links */
      document.addEventListener('click', function (e) {
        var link = e.target.closest('[data-logout-confirm]');
        if (!link) return;
        e.preventDefault();
        openModal(link.href);
      });

      /* Confirm */
      confirmBtn.addEventListener('click', function () {
        if (pendingHref) window.location.href = pendingHref;
      });

      /* Cancel */
      cancelBtn.addEventListener('click', closeModal);
      backdrop.addEventListener('click', function (e) {
        if (e.target === backdrop) closeModal();
      });

      /* Escape key → close */
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && backdrop.style.display === 'flex') closeModal();
      });

      /* Button hover micro-interactions */
      confirmBtn.addEventListener('mouseenter', function () { this.style.opacity = '0.88'; });
      confirmBtn.addEventListener('mouseleave', function () { this.style.opacity = '1'; });
      cancelBtn.addEventListener('mouseenter',  function () { this.style.background = '#e7e8e9'; });
      cancelBtn.addEventListener('mouseleave',  function () { this.style.background = '#f3f4f5'; });
    })();
    </script>
  </body>
</html>
