{#
  page--user--logout.html.twig
#}
{% set _ = attach_library('scholastic/page--user-auth') %}

<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light px-3 position-relative overflow-hidden">

  {# Decorative circles #}
  <div class="position-absolute rounded-circle pe-none"
       style="width:31rem;height:31rem;background:rgba(213,228,247,.2);top:0;right:0;transform:translate(50%,-50%);filter:blur(3rem);"></div>
  <div class="position-absolute rounded-circle pe-none"
       style="width:19rem;height:19rem;background:rgba(0,31,60,.05);bottom:0;left:0;transform:translate(-50%,50%);filter:blur(2rem);"></div>

  <div class="position-relative d-flex flex-column align-items-center gap-4 w-100" style="max-width:22rem; z-index:1;">

    {# Logo #}
    <a href="/" class="text-decoration-none">
      <span class="fw-bolder fs-5 font-headline" style="color:#001f3c;">Drupal Scholastic</span>
    </a>

    {# Card #}
    <div class="w-100 bg-white rounded-4 shadow border p-5 d-flex flex-column align-items-center gap-4">

      {# Icon #}
      <div class="rounded-circle bg-surface-container d-flex align-items-center justify-content-center"
           style="width:4rem; height:4rem;">
        <span class="fs-3" aria-hidden="true">&#x1F6AA;</span>
      </div>

      {# Heading #}
      <div class="text-center">
        <h1 class="h4 fw-bolder font-headline mb-1" style="color:#001f3c;">{{ 'Sign out?'|t }}</h1>
        <p class="small text-muted font-body lh-base mb-0">
          {{ "You'll be signed out of your Drupal Scholastic account. You can always sign back in."|t }}
        </p>
      </div>

      <div class="w-100 logout-form-wrapper">
        {{ page.content }}
      </div>

    </div>

    <a href="/" class="d-flex align-items-center gap-2 small text-muted text-decoration-none font-body">
      &larr; {{ 'Back to home'|t }}
    </a>

  </div>

</div>
