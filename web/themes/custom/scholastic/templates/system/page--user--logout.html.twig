{% set _ = attach_library('scholastic/page--user-auth') %}
<div class="min-h-screen flex items-center justify-center bg-surface px-4 relative overflow-hidden">

  {# Subtle background decoration #}
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-secondary-container/20 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-primary/5 rounded-full translate-y-1/2 -translate-x-1/2 blur-2xl pointer-events-none"></div>

  <div class="relative z-10 flex flex-col items-center gap-8 w-full max-w-sm">

    {# Logo #}
    <a href="/" class="no-underline">
      <div class="text-xl font-extrabold tracking-tighter text-primary font-headline">Drupal Scholastic</div>
    </a>

    {# Card #}
    <div class="w-full bg-white rounded-2xl shadow-xl shadow-primary/5 border border-surface-container-high p-10 flex flex-col items-center gap-6">

      {# Icon #}
      <div class="w-16 h-16 rounded-full bg-surface-container flex items-center justify-center">
        <span class="material-symbols-outlined text-primary" style="font-size:32px; font-variation-settings: 'FILL' 0, 'wght' 300;">logout</span>
      </div>

      {# Heading #}
      <div class="text-center">
        <h1 class="text-2xl font-extrabold text-primary font-headline mb-2">Sign out?</h1>
        <p class="text-sm text-on-surface-variant font-body leading-relaxed">
          You'll be signed out of your Drupal Scholastic account. You can always sign back in.
        </p>
      </div>

      <div class="w-full logout-form-wrapper">
        {{ page.content }}
      </div>

    </div>

    {# Back link #}
    <a href="/" class="flex items-center gap-2 text-xs text-on-surface-variant hover:text-primary transition-colors no-underline font-body">
      <span class="material-symbols-outlined" style="font-size:16px;">arrow_back</span>
      Back to home
    </a>

  </div>

</div>
