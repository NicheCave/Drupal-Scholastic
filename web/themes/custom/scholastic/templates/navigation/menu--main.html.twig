{#
  menu--main.html.twig
#}
<ul class="navbar-nav mb-2 mb-md-0">
  {% for item in items %}
    <li class="nav-item{% if item.in_active_trail %} active{% endif %}">
      <a class="nav-link{% if item.in_active_trail %} active{% endif %}"
         href="{{ item.url }}"
         {% if item.in_active_trail %}aria-current="page"{% endif %}>
        {{ item.title }}
      </a>
      {% if item.below %}
        <ul class="dropdown-menu">
          {% for child in item.below %}
            <li>
              <a class="dropdown-item{% if child.in_active_trail %} active{% endif %}"
                 href="{{ child.url }}">{{ child.title }}</a>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </li>
  {% endfor %}
</ul>
