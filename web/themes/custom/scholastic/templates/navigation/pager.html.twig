{#
  pager.html.twig — Theme-wide styled pager.

  Drupal variables:
    items.previous   → previous page (has .href and .text)
    items.pages      → array keyed by page number; each has .href
    items.next       → next page
    current          → 1-based current page number
    ellipses.previous, ellipses.next → boolean, show "…"
    heading_id       → aria heading id
    quantity         → number of page links shown
#}

{% if items %}
<nav class="flex items-center gap-2" aria-labelledby="{{ heading_id }}">
  <h4 id="{{ heading_id }}" class="sr-only">{{ "Pagination"|t }}</h4>

  {# ← Previous #}
  {% if items.previous %}
    <a href="{{ items.previous.href }}"
       {{ items.previous.attributes.addClass([
           'flex items-center justify-center w-10 h-10 rounded-lg',
           'border border-surface-container-high',
           'text-on-surface-variant hover:bg-surface-container',
           'hover:text-primary transition-colors no-underline'
         ]) }}>
      <span class="material-symbols-outlined" style="font-size:18px;">chevron_left</span>
    </a>
  {% else %}
    <span class="flex items-center justify-center w-10 h-10 rounded-lg
                 border border-surface-container-high
                 text-outline opacity-40 cursor-not-allowed">
      <span class="material-symbols-outlined" style="font-size:18px;">chevron_left</span>
    </span>
  {% endif %}

  {# … before first page if needed #}
  {% if ellipses.previous %}
    <span class="flex items-center justify-center w-10 h-10
                 text-outline text-sm font-body select-none">…</span>
  {% endif %}

  {# Page numbers #}
  {% for key, item in items.pages %}
    {% if current == key %}
      <span class="flex items-center justify-center w-10 h-10 rounded-lg
                   bg-primary text-on-primary
                   text-sm font-bold font-body"
            aria-current="page"
            aria-label="{{ 'Current page, page'|t }} {{ key }}">
        {{ key }}
      </span>
    {% else %}
      <a href="{{ item.href }}"
         {{ item.attributes.addClass([
             'flex items-center justify-center w-10 h-10 rounded-lg',
             'border border-surface-container-high',
             'text-on-surface-variant hover:bg-surface-container',
             'hover:text-primary text-sm font-body',
             'transition-colors no-underline'
           ]) }}
         aria-label="{{ 'Page'|t }} {{ key }}">
        {{ key }}
      </a>
    {% endif %}
  {% endfor %}

  {# … after last page if needed #}
  {% if ellipses.next %}
    <span class="flex items-center justify-center w-10 h-10
                 text-outline text-sm font-body select-none">…</span>
  {% endif %}

  {# → Next #}
  {% if items.next %}
    <a href="{{ items.next.href }}"
       {{ items.next.attributes.addClass([
           'flex items-center justify-center w-10 h-10 rounded-lg',
           'border border-surface-container-high',
           'text-on-surface-variant hover:bg-surface-container',
           'hover:text-primary transition-colors no-underline'
         ]) }}>
      <span class="material-symbols-outlined" style="font-size:18px;">chevron_right</span>
    </a>
  {% else %}
    <span class="flex items-center justify-center w-10 h-10 rounded-lg
                 border border-surface-container-high
                 text-outline opacity-40 cursor-not-allowed">
      <span class="material-symbols-outlined" style="font-size:18px;">chevron_right</span>
    </span>
  {% endif %}

</nav>
{% endif %}
