{#
  pager.html.twig — Bootstrap pagination.

  Drupal variables:
    items.previous / items.next  → prev/next page links
    items.pages                  → keyed array of page number links
    current                      → 1-based current page number
    ellipses.previous/next       → boolean, show "…"
    heading_id                   → aria heading id
#}

{% if items %}
<nav aria-labelledby="{{ heading_id }}">
  <h4 id="{{ heading_id }}" class="visually-hidden">{{ 'Pagination'|t }}</h4>

  <ul class="pagination justify-content-center gap-1 mb-0">

    {# ← Previous #}
    <li class="page-item{% if not items.previous %} disabled{% endif %}">
      {% if items.previous %}
        <a class="page-link rounded" href="{{ items.previous.href }}"
           {{ items.previous.attributes }} aria-label="{{ 'Previous page'|t }}">
          &lsaquo;
        </a>
      {% else %}
        <span class="page-link rounded" aria-hidden="true">&lsaquo;</span>
      {% endif %}
    </li>

    {# … before first shown page #}
    {% if ellipses.previous %}
      <li class="page-item disabled">
        <span class="page-link border-0 bg-transparent">…</span>
      </li>
    {% endif %}

    {# Page numbers #}
    {% for key, item in items.pages %}
      <li class="page-item{% if current == key %} active{% endif %}">
        {% if current == key %}
          <span class="page-link rounded fw-bold"
                aria-current="page"
                aria-label="{{ 'Current page, page'|t }} {{ key }}">
            {{ key }}
          </span>
        {% else %}
          <a class="page-link rounded"
             href="{{ item.href }}"
             {{ item.attributes }}
             aria-label="{{ 'Page'|t }} {{ key }}">
            {{ key }}
          </a>
        {% endif %}
      </li>
    {% endfor %}

    {# … after last shown page #}
    {% if ellipses.next %}
      <li class="page-item disabled">
        <span class="page-link border-0 bg-transparent">…</span>
      </li>
    {% endif %}

    {# → Next #}
    <li class="page-item{% if not items.next %} disabled{% endif %}">
      {% if items.next %}
        <a class="page-link rounded" href="{{ items.next.href }}"
           {{ items.next.attributes }} aria-label="{{ 'Next page'|t }}">
          &rsaquo;
        </a>
      {% else %}
        <span class="page-link rounded" aria-hidden="true">&rsaquo;</span>
      {% endif %}
    </li>

  </ul>
</nav>
{% endif %}
