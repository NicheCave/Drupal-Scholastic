{#
  paragraph--honor-item.html.twig
  Fields: field_honor_icon, field_honor_title, field_honor_description
#}

<div class="sc-honor-card d-flex align-items-start gap-3 py-3 border-bottom">

  {% if paragraph.field_honor_icon.value %}
    <span class="material-symbols-outlined scholastic-icon scholastic-icon--sm flex-shrink-0"
          aria-hidden="true"
          style="margin-top:.125rem;">
      {{- paragraph.field_honor_icon.value -}}
    </span>
  {% endif %}

  <div class="d-flex flex-column gap-1">
    {% if content.field_honor_title|render %}
      <h4 class="h6 fw-bold font-headline mb-0" style="color:#001f3c; letter-spacing:-.01em;">
        {{ content.field_honor_title }}
      </h4>
    {% endif %}
    {% if content.field_honor_description|render %}
      <p class="small text-on-surface-variant font-body mb-0 lh-base">
        {{ content.field_honor_description }}
      </p>
    {% endif %}
  </div>

</div>
