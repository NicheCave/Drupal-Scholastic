{#
  paragraph--honor-item.html.twig
  FOLDER: themes/custom/scholastic/templates/paragraph/

  Renders one row in the "Professional Honors" list on the About page.

  ── PARAGRAPH TYPE SETUP ────────────────────────────────────────────
  Structure → Paragraph types → Add paragraph type
    Label:        Honor Item
    Machine name: honor_item

  Then add these fields:
    field_icon              Text (plain)       Material Symbols name
                            e.g. "verified", "chat", "emoji_events", "school"
                            Browse: https://fonts.google.com/icons
    field_honor_title       Text (plain)       "Acquia Certified Grand Master"
    field_honor_description Text (plain, long) single-line description
  ────────────────────────────────────────────────────────────────────

  The parent template (node--about.html.twig) uses display:contents to
  flatten Drupal's field wrappers, so this paragraph is a direct flex
  child of .about-honors-list.
#}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet">

<div class="honor-item" 
     style="display: flex; flex-direction: row; align-items: center; gap: 1.25rem; padding: 0.875rem 0;">

  {# ── Fixed-size Icon ── #}
  {% if paragraph.field_honor_icon.value %}
    <span class="material-symbols-outlined" 
          style="color: #1460a4; font-size: 32px; flex: none; width: 32px;
                 font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 40;">
      {{- paragraph.field_honor_icon.value -}}
    </span>
  {% endif %}

  {# ── Text Block (Takes remaining space) ── #}
  <div style="flex: 1; display: flex; flex-direction: column; gap: 0.125rem;">
    {% if content.field_honor_title|render %}
      <h4 class="text-base font-bold text-primary font-headline m-0" style="letter-spacing: -0.01em; line-height: 1.2;">
        {{ content.field_honor_title }}
      </h4>
    {% endif %}
    
    {% if content.field_honor_description|render %}
      <p class="text-sm text-on-surface-variant font-body m-0 leading-relaxed" style="opacity: 0.9;">
        {{ content.field_honor_description }}
      </p>
    {% endif %}
  </div>

</div>