{#
  paragraph--feature-item.html.twig
  Fields: field_icon, field_title, field_description
  Icon: Material Symbols Outlined ligature name stored in field_icon.
#}

{# Outer sc-feature-card wrapper catches the hover; inner div holds styling #}
<div class="sc-feature-card h-100">
  <div class="bg-surface p-4 p-lg-5 d-flex flex-column gap-3 h-100">

    {% set icon_name = content.field_icon|render|striptags|trim %}
    {% if icon_name %}
      <span class="material-symbols-outlined scholastic-icon" aria-hidden="true">
        {{- icon_name -}}
      </span>
    {% endif %}

    {% if content.field_title|render %}
      <h3 class="h5 fw-bold font-headline lh-sm mb-0" style="color:#001f3c;">
        {{ content.field_title }}
      </h3>
    {% endif %}

    {% if content.field_description|render %}
      <p class="small text-on-surface-variant lh-base font-body mb-0">
        {{ content.field_description }}
      </p>
    {% endif %}

  </div>
</div>
